# =========================================================================
# LEGAL AI PIPELINE CONFIGURATION TEMPLATE
# Instructions: Copy this file, rename it to '.env', and fill in placeholders.
# =========================================================================

PORT=5000
NODE_ENV=development

# Database connection placeholder
MONGO_URI=mongodb://localhost:27017/your_local_db_name

# JSON Web Token parameters
JWT_SECRET=enter_a_random_32_character_string_here
JWT_EXPIRE=7d

# Developer Web Services API Key
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Production address configuration
FRONTEND_PRODUCTION_URL=https://your-deployed-frontend-link.com

# Mail transport connection parameters
SMTP_HOST=smtp.yourmailprovider.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
FROM_EMAIL=noreply@yourdomain.com