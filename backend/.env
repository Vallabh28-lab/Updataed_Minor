# =========================================================================
# SERVER CONFIGURATION
# =========================================================================
PORT=5000
NODE_ENV=development

# =========================================================================
# DATABASE CONFIGURATION
# Swap localhost string for your cloud MongoDB Atlas connection line on deploy
# =========================================================================
MONGO_URI=mongodb://localhost:27017/legal_case_db

# =========================================================================
# SECURITY & TOKEN MANAGEMENT
# Run 'node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"' 
# in your terminal to generate a strong unique string for production.
# =========================================================================
JWT_SECRET=4f7a29e18b6c43d9a0d2f8e7c1b5a3e9c6d4f8b2a1c7d3e6f9a0b2c4d6e8f1a2
JWT_EXPIRE=7d

# =========================================================================
# THIRD-PARTY INTEGRATIONS
# Replace with your secure, newly-generated credentials from Google Cloud Console
# =========================================================================
GOOGLE_PLACES_API_KEY=AIzaSyYourNewSecureRotatedGoogleKeyHere

# =========================================================================
# DEPLOYMENT CORS WHITELIST
# Tells server.js exactly which frontend link can look at database variables
# =========================================================================
FRONTEND_PRODUCTION_URL=https://your-legal-ai-frontend.vercel.app

# =========================================================================
# TRANSACTIONAL EMAIL SYSTEM (For Sending Password Reset Verification Emails)
# Setup a free profile on Resend or Brevo to fill these settings out
# =========================================================================
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=re_your_secret_mail_integration_api_key_here
FROM_EMAIL=noreply@legalai.com